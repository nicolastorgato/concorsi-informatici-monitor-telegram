# Bot Telegram
# Ottieni il token creando un bot con @BotFather su Telegram
TELEGRAM_TOKEN=il_tuo_token_qui

# Il tuo Chat ID numerico
# Invia un messaggio al bot, poi vai su https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=il_tuo_chat_id_qui

# Chiave API OpenRouter
# Creala su https://openrouter.ai/keys
OPENROUTER_API_KEY=la_tua_chiave_qui

# Il tuo profilo professionale
# Usato dall'AI per valutare se un bando fa al caso tuo
# Esempio: Laurea in Informatica, 5 anni esperienza PA, competenze PHP Python Laravel, distanza massima 40km da Treviso
PROFILO=il_tuo_profilo_qui